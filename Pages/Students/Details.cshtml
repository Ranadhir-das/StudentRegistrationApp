@page
@model StudentRegistrationApp.Pages.Students.DetailsModel
@{
    ViewData["Title"] = "Student Details";
}

<div class="student-details-container mt-4 no-print">
    <h1>Student Details</h1>
    <hr />

    <div class="row">
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-4">Full Name</dt>
                <dd class="col-sm-8">@Model.Student.FullName</dd>

                <dt class="col-sm-4">Date of Birth</dt>
                <dd class="col-sm-8">@Model.Student.DOB.ToShortDateString()</dd>

                <dt class="col-sm-4">Registration No</dt>
                <dd class="col-sm-8 fw-bold text-primary">@Model.Student.RegistrationNo</dd>

                <dt class="col-sm-4">Phone Number</dt>
                <dd class="col-sm-8">@Model.Student.PhoneNumber</dd>
            </dl>
        </div>

        <div class="col-md-4 text-center">
            @if (!string.IsNullOrEmpty(Model.Student.PassportPhotoPath))
            {
                <img src="@Url.Content(Model.Student.PassportPhotoPath)" class="img-thumbnail" style="width:200px;" />
            }
            else
            {
                <div class="p-5 border bg-light text-muted">No Photo Available</div>
            }
        </div>
    </div>

    <div class="mt-4">
        <a asp-page="./Edit" asp-route-id="@Model.Student?.ID" class="btn btn-danger">Edit</a>
    </div>
    <div class="mt-4 print">   
        <a asp-page-handler="DownloadPdf" asp-route-id="@Model.Student?.ID" class="btn btn-primary">
            <i class="bi bi-file-pdf"></i> Download PDF
        </a>

        <button onclick="window.print()" class="btn btn-success">
            <i class="bi bi-printer"></i> Print
        </button>
    </div>
</div>

<div class="certificate-print-area">
    <div class='certificate-container'>
        <div class='header'>
            @* Update the src to your university logo path *@
            <img src='/assets/logo.jpeg' class='logo' alt="Logo" />
            <p class='university-name'>Kazi Nazrul University</p>
            <p class='university-address'>Asansol, Paschim Bardhaman, West Bengal - 713302</p>
            <div class='doc-title'>REGISTRATION CERTIFICATE</div>
        </div>

        <div class='content-row'>
            <div class='details-column'>
                <table>
                    <tr><th>Full Name</th><td>@Model.Student.FullName</td></tr>
                    <tr><th>Registration No</th><td>@Model.Student.RegistrationNo</td></tr>
                    <tr><th>Date of Birth</th><td>@Model.Student.DOB.ToShortDateString()</td></tr>
                    <tr><th>Phone Number</th><td>@Model.Student.PhoneNumber</td></tr>
                    <tr><th>Date of Issue</th><td>@DateTime.Now.ToShortDateString()</td></tr>
                </table>
            </div>

            <div class='photo-column'>
                <img src='@Url.Content(Model.Student.PassportPhotoPath)' class='photo' />
            </div>
        </div>

        <div class='footer-sig'>
            <div class='sig-box'>
                Registrar Signature
            </div>
        </div>
    </div>
</div>

<style>
    /* 1. Web View (No changes) */
    .student-details-container { padding-left: 100px; min-height: 90vh; max-width: 90%; }
    .row { font-size: 20px; }
    .certificate-print-area { display: none; }
    .print {
        display: flex;
        flex-direction: column;
        width: 500px;
        height: 100px;
        row-gap: 20px;

    }

    /* 2. Professional Print Styling */
    @@media print {
        /* Kill all web elements and their layout influence */
        .no-print, .navbar, footer, header, .btn, .student-details-container, h1, hr { 
            display: none !important; 
        }

        @@page { 
            size: A4 portrait; 
            margin: 0; /* Important: removes browser-added whitespace */
        }
        
        body { 
            background: white !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        /* THE TOP-PINNED FIX */
        .certificate-print-area { 
            display: block !important; 
            position: absolute !important;
            top: 0 !important;
            left: 0 !important;
            width: 21cm !important; /* Full A4 Width */
            padding: 0.5cm !important; /* Small margin so the border doesn't get cut */
        }

        .certificate-container { 
            display: block !important;
            border: 10px double #1a237e !important; 
            padding: 25px !important; 
            width: 20cm !important;  /* Extended width to fill the page */
            height: 13.5cm !important; /* Slightly taller for better scale */
            background: white !important;
            box-sizing: border-box !important;
            -webkit-print-color-adjust: exact !important;
        }

        /* Internal Layout */
        .content-row { 
            display: table !important; 
            width: 100% !important; 
            margin-top: 20px !important;
        }

        .details-column { 
            display: table-cell !important; 
            width: 70% !important; 
            vertical-align: top !important;
        }

        .photo-column { 
            display: table-cell !important; 
            width: 30% !important; 
            vertical-align: top !important;
            text-align: right !important;
        }

        .photo { 
            width: 140px !important; 
            height: 175px !important; 
            border: 2px solid #1a237e !important; 
            object-fit: cover !important;
        }

        /* Typography Scaling for the wider box */
        .header { text-align: center; border-bottom: 2px solid #1a237e; margin-bottom: 5px; }
        .university-name { font-size: 20pt !important; font-weight: bold; color: #1a237e !important; margin: 0; }
        .doc-title { font-size: 18pt !important; color: #d32f2f !important; margin-top: 8px; font-weight: bold; }
        
        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; font-size: 11pt; padding: 8px; color: #555; }
        td { font-size: 13pt; font-weight: bold; padding: 8px; border-bottom: 1px solid #eee; }
        .logo { height: 60px; width: auto; margin-bottom: 5px; }

        /* Signature placement */
        .footer-sig { 
            position: absolute; 
            bottom: 30px; 
            right: 40px; 
            text-align: center; 
        }
        .sig-box { 
            border-top: 1px solid #333; 
            width: 200px; 
            padding-top: 5px; 
            font-weight: bold; 
            font-size: 11pt;
        }
    }
</style>