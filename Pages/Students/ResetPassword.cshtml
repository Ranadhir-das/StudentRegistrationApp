@page
@model StudentRegistrationApp.Pages.Students.ResetPasswordModel
@{
    ViewData["Title"] = "Verify OTP";
}

<div class="otp-container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-body">
                    <h2 class="text-center mb-4">Reset Password</h2>

                    @if (TempData["StatusMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            @TempData["StatusMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form method="post">
                        <input type="hidden" asp-for="Email" />
                        
                        <!-- <div class="form-group mb-3">
                            <label class="form-label">Verification Code (OTP)</label>
                            <input asp-for="OTP" class="form-control text-center" placeholder="000000" maxlength="6" required style="font-size: 1.2rem; letter-spacing: 5px;" />
                            <span asp-validation-for="OTP" class="text-danger"></span>
                        </div> -->
                        <div class="form-group mb-4">
                            <label class="form-label d-block text-center fw-bold">Enter Verification Code</label>
                            <div id="otp-inputs" class="d-flex justify-content-between mx-auto" style="max-width: 300px;">
                                <input type="text" class="form-control otp-box" maxlength="1" required />
                                <input type="text" class="form-control otp-box" maxlength="1" required />
                                <input type="text" class="form-control otp-box" maxlength="1" required />
                                <input type="text" class="form-control otp-box" maxlength="1" required />
                                <input type="text" class="form-control otp-box" maxlength="1" required />
                                <input type="text" class="form-control otp-box" maxlength="1" required />
                            </div>
                            <input type="hidden" asp-for="OTP" id="hiddenOtp" />
                        </div>

                        <div class="text-center mt-3">
                            <p id="timer-container" class="text-muted small">
                                Resend code in <span id="countdown" class="fw-bold">60</span> seconds
                            </p>
                            
                            <a id="resend-link" asp-page-handler="SendOtp" asp-route-email="@Model.Email" 
                               class="btn btn-link btn-sm d-none fw-bold text-decoration-none">
                                <i class="bi bi-arrow-clockwise"></i> Resend Verification Code
                            </a>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Enter New Password</label>
                            <input asp-for="NewPassword" type="password" class="form-control" placeholder="Minimum 6 characters" required />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2">Update Password</button>
                    </form>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger mt-3 pb-0">
                            <div asp-validation-summary="All"></div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>


<style>
    .otp-box {
        width: 45px;
        height: 55px;
        text-align: center;
        font-size: 1.5rem;
        font-weight: bold;
        margin: 0 5px;
        border: 2px solid #ced4da;
        border-radius: 8px;
    }
    .otp-box:focus {
        border-color: #007bff;
        box-shadow: 0 0 8px rgba(0, 123, 255, 0.25);
    }
    .otp-container {
        min-height: 90vh;
    }
</style>

@section Scripts {
<script>
    // --- Combined OTP & Timer Logic ---
    const inputs = document.querySelectorAll('.otp-box');
    const hiddenInput = document.getElementById('hiddenOtp');
    const countdownElement = document.getElementById('countdown');
    const timerContainer = document.getElementById('timer-container');
    const resendLink = document.getElementById('resend-link');

    // 1. Handle OTP Box Movement
    inputs.forEach((input, index) => {
        input.addEventListener('input', (e) => {
            if (e.target.value.length === 1 && index < inputs.length - 1) {
                inputs[index + 1].focus();
            }
            updateHiddenInput();
        });

        input.addEventListener('keydown', (e) => {
            if (e.key === 'Backspace' && !e.target.value && index > 0) {
                inputs[index - 1].focus();
            }
        });
    });

    function updateHiddenInput() {
        let otpValue = "";
        inputs.forEach(input => { otpValue += input.value; });
        hiddenInput.value = otpValue;
    }

    // 2. Handle Countdown Timer
    let timeLeft = 60; 
    const timer = setInterval(() => {
        if (timeLeft <= 0) {
            clearInterval(timer);
            timerContainer.classList.add('d-none');
            resendLink.classList.remove('d-none');
        } else {
            countdownElement.innerText = timeLeft;
        }
        timeLeft -= 1;
    }, 1000);
</script>
}